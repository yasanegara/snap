# Kunci rahasia buat sesi login (bikin sendiri, jangan pakai contoh ini di production)
SESSION_SECRET=ganti-dengan-teks-acak-yang-panjang

# Ambil dari dashboard Midtrans kamu (Settings > Access Keys)
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxxx

# false = mode sandbox/testing, true = mode asli (transaksi beneran)
MIDTRANS_IS_PRODUCTION=false

PORT=3000
